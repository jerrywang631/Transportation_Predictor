PORT=3001
WEATHER_API_KEY=your_weatherapi_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_INTENT_DEBUG=false
VITE_ASSISTANT_DEBUG=false
TICKETMASTER_API_KEY=your_ticketmaster_discovery_api_key_here
TOMTOM_API_KEY=your_tomtom_traffic_api_key_here
SERPAPI_API_KEY=your_serpapi_key_here
RESEND_API_KEY=your_resend_api_key_here
FEEDBACK_FROM_EMAIL="Milk Transit Feedback <onboarding@resend.dev>"
ROUTING_PROVIDER=auto
# Backend-only Google Maps Platform key.
# Used by local-info lookups through Google Places and Google Routes.
# It is also an optional paid routing fallback when ROUTING_PROVIDER=google or auto.
GOOGLE_MAPS_API_KEY=
DATA_DIR=./data
GTFS_ZIP_URL=https://example.com/ttc-gtfs.zip
GTFS_ZIP_PATH=./data/source/ttc-gtfs.zip
GTFS_SOURCE_DIR=./data/source/gtfs
GTFS_IMPORT_MODE=full
GTFS_DB_PATH=./data/gtfs.sqlite
GTFS_SLIM_DB_PATH=./data/gtfs-slim.sqlite
GTFS_WINDOW_DAYS=14
TTC_SERVICE_PERIOD=auto
TTC_GTFS_RT_TRIP_UPDATES_URL=https://gtfsrt.ttc.ca/trips/update?format=text
OTP_BASE_URL=http://localhost:8080
# Use the current clock time on the same weekday inside the GTFS feed calendar.
# Set this to a fixed ISO datetime only when you need a deterministic demo.
OTP_PLAN_DATETIME=match-weekday
OTP_GTFS_SERVICE_START_DATE=2026-06-21
GTHA_GTFS_FEEDS_FILE=./config/gtha-gtfs-feeds.json
GTHA_GTFS_OUTPUT_DIR=./data/otp
REGIONAL_TRANSIT_FEEDS_FILE=./config/regional-transit-feeds.json
REGIONAL_TRANSIT_OUTPUT_DIR=./data/otp
REGIONAL_TRANSIT_ARRIVALS_DB_PATH=./data/regional-arrivals.sqlite
REGIONAL_TRANSIT_WINDOW_DAYS=14
CONSTRUCTION_GEOJSON_URL=https://example.com/road-reconstruction-program.geojson
CONSTRUCTION_GEOJSON_PATH=./data/construction/road-reconstruction-program.geojson
PLANET_DATA_URL=https://example.com/toronto.osm.pbf
PLANET_DATA_PATH=./data/planet.osm.pbf
